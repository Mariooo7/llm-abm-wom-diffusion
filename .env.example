# LLM 配置（阿里百炼 OpenAI 兼容接口）
LLM_PROVIDER=aliyun_bailian
LLM_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen3.5-flash
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.2
LLM_SEED=42
LLM_ENABLE_THINKING=false
LLM_RETRY_MAX_ATTEMPTS=8
LLM_RETRY_BASE_MS=600
LLM_RETRY_JITTER_MS=300
LLM_MAX_INFLIGHT=3
LLM_REQUEST_TIMEOUT_SECONDS=180
LLM_SERVER_ADDR=127.0.0.1:18080

# 实验配置
EXPERIMENT_GROUP=A
N_REPETITIONS=15
USE_LLM=true
REPETITIONS=15
REPETITION_WORKERS=3
RUN_RETRIES=2
RETRY_BACKOFF_SECONDS=3
TIMEOUT_SECONDS=210

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=experiments/logs/simulation.log
